{
  "$schema": "../gen/schemas/remote-schema.json",
  "identifier": "desktop-localhost",
  "description": "Allow Tapedeck's bundled localhost UI to use its narrow desktop commands.",
  "windows": ["main"],
  "remote": {
    "urls": ["http://localhost:14321", "http://127.0.0.1:5173"]
  },
  "permissions": [
    "core:default",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "allow-google-auth-status",
    "allow-sign-in-with-google",
    "allow-sign-out-google",
    "allow-resolve-youtube-source",
    "allow-resolve-video",
    "allow-media-set-metadata",
    "allow-media-set-playback",
    "allow-load-library",
    "allow-save-library",
    "allow-export-library",
    "allow-drive-download-library",
    "allow-drive-upload-library",
    "allow-drive-touch-device"
  ]
}
