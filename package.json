{
  "name": "tapedeck",
  "private": true,
  "version": "0.2.5",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names api,web \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.js",
    "tauri": "tauri",
    "desktop": "tauri dev",
    "desktop:build": "tauri build",
    "desktop:icon": "tauri icon src-tauri/icons/app-icon.svg && npm run desktop:icon:macos",
    "desktop:icon:macos": "node scripts/compile-macos-icon.mjs",
    "build": "tsc -b && vite build",
    "start": "node server/index.js",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/youtube": "^0.1.2",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.1",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
