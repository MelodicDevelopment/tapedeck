# Desktop app: create an OAuth client with application type "Desktop app".
# This public client ID is embedded at build time; never add a client secret.
TAPEDECK_GOOGLE_CLIENT_ID=

# Browser/Express fallback only: create a YouTube Data API v3 key.
# Keep this server-only name; do not prefix it with VITE_.
YOUTUBE_API_KEY=

# Optional server settings
PORT=8787
YOUTUBE_MAX_TRACKS=150
YOUTUBE_CACHE_TTL_MS=600000

# Browser fallback only: public URL of a deployed Tapedeck API.
# The self-contained desktop app does not use this value.
VITE_API_BASE_URL=

# Additional comma-separated web origins allowed to call the hosted API.
CORS_ORIGINS=
