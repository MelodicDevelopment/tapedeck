# Desktop app: create an OAuth client with application type "Desktop app".
# Both values are embedded at build time. Google requires the client secret at
# the token endpoint even for PKCE, and documents that installed-app secrets
# are not confidential — but still keep them out of source control.
TAPEDECK_GOOGLE_CLIENT_ID=
TAPEDECK_GOOGLE_CLIENT_SECRET=

# Browser/Express fallback only: create a YouTube Data API v3 key.
# Keep this server-only name; do not prefix it with VITE_.
YOUTUBE_API_KEY=

# Optional server settings
PORT=8787
YOUTUBE_MAX_TRACKS=150
YOUTUBE_CACHE_TTL_MS=600000

# Browser fallback only: public URL of a deployed Tapedeck API.
# The self-contained desktop app does not use this value.
VITE_API_BASE_URL=

# Additional comma-separated web origins allowed to call the hosted API.
CORS_ORIGINS=

# --- Release signing (CI only — set as GitHub Actions secrets, not here) ---
# .github/workflows/release.yml builds and publishes a draft GitHub Release
# on every "v*" tag push. These are never read from a local .env file; they
# only need to exist as repo secrets (Settings -> Secrets and variables ->
# Actions) or org/environment secrets.

# macOS signing + notarization — consumed directly by tauri-bundler.
# APPLE_CERTIFICATE is a base64-encoded .p12 export of your "Developer ID
# Application" certificate; APPLE_ID/APPLE_PASSWORD/APPLE_TEAM_ID authenticate
# with notarytool (APPLE_PASSWORD is an app-specific password from
# appleid.apple.com, not your account password).
#   APPLE_CERTIFICATE=
#   APPLE_CERTIFICATE_PASSWORD=
#   APPLE_SIGNING_IDENTITY=
#   APPLE_ID=
#   APPLE_PASSWORD=
#   APPLE_TEAM_ID=

# Windows signing via Azure Trusted Signing — consumed by
# scripts/sign-windows.mjs through the bundle.windows.signCommand hook in
# src-tauri/tauri.conf.json. Same convention as Envy/Coax: an Entra ID app
# registration with the "Artifact Signing Certificate Profile Signer" role
# on the Trusted Signing account/profile.
#   AZURE_TENANT_ID=
#   AZURE_CLIENT_ID=
#   AZURE_CLIENT_SECRET=
#   TRUSTED_SIGNING_ENDPOINT=
#   TRUSTED_SIGNING_ACCOUNT=
#   TRUSTED_SIGNING_PROFILE=
